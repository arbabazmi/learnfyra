ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key
DEFAULT_OUTPUT_DIR=./worksheets
DEFAULT_FORMAT=pdf
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_RETRIES=3

# Set to true to skip real Anthropic API calls during local development.
# Returns parameterized mock data instantly — no credits consumed.
# Set to false (or remove) when you want to test with real AI output.
MOCK_AI=true

# Auth & database (Phase 3 — local-first)
AUTH_MODE=mock
APP_RUNTIME=local
JWT_SECRET=learnfyra-local-dev-secret
DDB_TABLE_PREFIX=learnfyra-local

# COPPA consent emails (production only — local dev uses console.log)
SES_FROM_EMAIL=noreply@learnfyra.com
