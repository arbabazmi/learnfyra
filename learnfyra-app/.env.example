# ─────────────────────────────────────────────────────────────
# Learnfyra — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── App URL (used to build OAuth redirect URIs) ───────────────
# dev:        leave blank — auto-detected from window.location
# staging:    https://staging.learnfyra.com
# production: https://learnfyra.com
VITE_APP_URL=

# ── API / Express backend ──────────────────────────────────────
# dev:        http://localhost:3000  (default — can omit)
# staging/prod: leave blank — API is same origin via API Gateway
VITE_API_URL=

# ── Google OAuth ───────────────────────────────────────────────
# Client ID from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Override the redirect URI if needed.
# Default behaviour:
#   dev  → http://localhost:3000/auth/google/callback
#   prod → {VITE_APP_URL}/auth/google/callback
# Must exactly match the URI registered in Google Cloud Console.
VITE_GOOGLE_REDIRECT_URI=
