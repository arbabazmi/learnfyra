              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type",  "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Factors and Multiples\",\n  \"difficulty\": \"Easy\",\n  \"questionType\": \"multiple-choice\",\n  \"count\": 3\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
