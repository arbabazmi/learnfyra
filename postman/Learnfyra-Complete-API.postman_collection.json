{
  "info": {
    "_postman_id": "learnfyra-complete-api-2026",
    "name": "Learnfyra Complete API — All Ready Endpoints",
    "description": "Comprehensive test collection for Learnfyra API. Tests all implemented endpoints for local dev and AWS Lambda deployments.\n\n**Setup Instructions:**\n1. Set `baseUrl` variable to your environment (http://localhost:3000 for local)\n2. Run Auth section first — Login scripts auto-capture tokens\n3. Run sections in order; each section depends on IDs captured above\n4. For local testing: ensure `node server.js` is running with MOCK_AI=true",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",                  "value": "http://localhost:3000", "type": "string" },
    { "key": "studentToken",             "value": "",                      "type": "string" },
    { "key": "teacherToken",             "value": "",                      "type": "string" },
    { "key": "adminToken",               "value": "",                      "type": "string" },
    { "key": "parentToken",              "value": "",                      "type": "string" },
    { "key": "worksheetId",              "value": "",                      "type": "string" },
    { "key": "classId",                  "value": "",                      "type": "string" },
    { "key": "studentId",                "value": "",                      "type": "string" },
    { "key": "questionId",               "value": "",                      "type": "string" },
    { "key": "certificateId",            "value": "",                      "type": "string" },
    { "key": "certificateDownloadToken", "value": "",                      "type": "string" },
    { "key": "inviteCode",               "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "description": "Auth flow: Register → Login (captures tokens) → Logout. Run Login requests before any protected endpoint.",
      "item": [
        {
          "name": "Register (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Passw0rd123!\",\n  \"role\": \"student\",\n  \"displayName\": \"Test Student\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": []
        },
        {
          "name": "Register (Teacher)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"Passw0rd123!\",\n  \"role\": \"teacher\",\n  \"displayName\": \"Test Teacher\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": []
        },
        {
          "name": "Register (Parent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\",\n  \"password\": \"Passw0rd123!\",\n  \"role\": \"parent\",\n  \"displayName\": \"Test Parent\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": []
        },
        {
          "name": "Login (Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.token)  pm.collectionVariables.set('studentToken', body.token);",
                  "  if (body.userId) pm.collectionVariables.set('studentId', body.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Passw0rd123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Login (Teacher)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.token)  pm.collectionVariables.set('teacherToken', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"Passw0rd123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Login (Parent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('parentToken', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\",\n  \"password\": \"Passw0rd123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/auth/logout"
          },
          "response": []
        },
        {
          "name": "OAuth Start (Google)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"redirectUri\": \"{{baseUrl}}/api/auth/callback/google\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/oauth/google"
          },
          "response": []
        },
        {
          "name": "OAuth Callback (Google)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/callback/google?code=sample-code&state=sample-state"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Worksheet Generation & Delivery",
      "description": "Worksheet lifecycle: Generate → Solve → Submit → Download",
      "item": [
        {
          "name": "Generate Worksheet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.metadata && body.metadata.id) {",
                  "    pm.collectionVariables.set('worksheetId', body.metadata.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Factors and Multiples\",\n  \"difficulty\": \"Easy\",\n  \"questionCount\": 10,\n  \"format\": \"HTML\",\n  \"includeAnswerKey\": true,\n  \"generationMode\": \"auto\",\n  \"provenanceLevel\": \"summary\",\n  \"studentName\": \"Test Student\",\n  \"teacherName\": \"Test Teacher\",\n  \"period\": \"Period 1\",\n  \"className\": \"Test Class\"\n}"
            },
            "url": "{{baseUrl}}/api/generate"
          },
          "response": []
        },
        {
          "name": "Get Solve Page (No Answers)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/solve/{{worksheetId}}"
          },
          "response": []
        },
        {
          "name": "Submit Answers & Score",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  console.log('Score: ' + body.percentage + '%');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"worksheetId\": \"{{worksheetId}}\",\n  \"studentName\": \"Test Student\",\n  \"answers\": [\n    { \"number\": 1, \"answer\": \"B\" },\n    { \"number\": 2, \"answer\": \"True\" },\n    { \"number\": 3, \"answer\": \"42\" },\n    { \"number\": 4, \"answer\": \"B\" },\n    { \"number\": 5, \"answer\": \"mock answer\" },\n    { \"number\": 6, \"answer\": \"20\" },\n    { \"number\": 7, \"answer\": \"mock answer\" },\n    { \"number\": 8, \"answer\": \"True\" },\n    { \"number\": 9, \"answer\": \"B\" },\n    { \"number\": 10, \"answer\": \"42\" }\n  ],\n  \"timeTaken\": 600,\n  \"timed\": false\n}"
            },
            "url": "{{baseUrl}}/api/submit"
          },
          "response": []
        },
        {
          "name": "Download Worksheet File",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/download?key=local/{{worksheetId}}/worksheet.html"
          },
          "response": []
        },
        {
          "name": "Generate Questions (M08)",
          "description": "LLM question generation pipeline — POST /api/generate-questions\nValid questionTypes: multiple-choice | true-false | fill-in-the-blank | short-answer | word-problem | show-your-work\ncount: 1–30, difficulty: Easy | Medium | Hard | Mixed",
          "item": [
            {
