    {
      "name": "9. Certificates",
      "description": "Student certificates. All endpoints require student Bearer token. List request auto-captures certificateId.",
      "item": [
        {
          "name": "List Certificates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.certificates && jsonData.certificates.length > 0) {",
                  "  var cert = jsonData.certificates[0];",
                  "  pm.collectionVariables.set('certificateId', cert.certificateId || cert.id);",
                  "  console.log('certificateId captured: ' + (cert.certificateId || cert.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/certificates?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "certificates"],
              "query": [
                { "key": "limit",  "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Download Certificate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/certificates/{{certificateId}}/download",
              "host": ["{{baseUrl}}"],
              "path": ["api", "certificates", "{{certificateId}}", "download"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "10. Question Bank",
      "description": "Question bank CRUD. GET endpoints are unauthenticated. POST endpoints require Bearer token. Deduplication on (grade, subject, topic, type, question-text).",
      "item": [
        {
          "name": "List Questions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/qb/questions?grade=4&subject=Math&difficulty=Easy&type=multiple-choice",
              "host": ["{{baseUrl}}"],
              "path": ["api", "qb", "questions"],
              "query": [
                { "key": "grade",      "value": "4" },
                { "key": "subject",    "value": "Math" },
                { "key": "difficulty", "value": "Easy" },
                { "key": "type",       "value": "multiple-choice" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Add Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "  pm.collectionVariables.set('questionId', jsonData.id);",
                  "  console.log('questionId captured: ' + jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Fractions\",\n  \"difficulty\": \"Medium\",\n  \"type\": \"multiple-choice\",\n  \"question\": \"What is 1/2 of 20?\",\n  \"options\": [\"A. 8\", \"B. 10\", \"C. 12\", \"D. 15\"],\n  \"answer\": \"B\",\n  \"explanation\": \"1/2 multiplied by 20 equals 10.\",\n  \"points\": 1,\n  \"standards\": [\"CCSS.MATH.CONTENT.4.NF.B.3\"]\n}"
            },
            "url": "{{baseUrl}}/api/qb/questions"
          },
          "response": []
        },
        {
          "name": "Get Question by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}"
          },
          "response": []
        },
        {
          "name": "Track Question Reuse",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}/reuse"
          },
          "response": []
        }
      ]
    },
    {
      "name": "11. Admin",
      "description": "Admin control plane — system policies, audit events. All endpoints require admin role Bearer token. PUT endpoints also require Idempotency-Key header (same key within 24h returns cached response).",
      "item": [
        {
          "name": "Get Global Policies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/policies"
          },
          "response": []
        },
        {
          "name": "Update Model Routing",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key", "value": "model-routing-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultMode\": \"auto\",\n  \"allowPremium\": true,\n  \"premiumEscalation\": {\n    \"missingCountThreshold\": 15,\n    \"hardQuestionCountThreshold\": 10\n  },\n  \"fallbackOrder\": [\"low\", \"default\", \"premium\"],\n  \"reason\": \"Update model routing policy.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/model-routing"
          },
          "response": []
        },
        {
          "name": "Update Budget Usage",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key", "value": "budget-usage-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dailyUsdSoftLimit\": 100,\n  \"dailyUsdHardLimit\": 150,\n  \"monthlyUsdSoftLimit\": 2500,\n  \"monthlyUsdHardLimit\": 3000,\n  \"softLimitBehavior\": \"log-only\",\n  \"hardLimitBehavior\": \"block-premium\",\n  \"reason\": \"Update budget controls.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/budget-usage"
          },
          "response": []
        },
        {
          "name": "Update Validation Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key", "value": "validation-profile-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"standard\",\n  \"strictness\": \"balanced\",\n  \"rejectOnCountMismatch\": true,\n  \"rejectOnSchemaViolation\": true,\n  \"allowPartialIfRecoverable\": false,\n  \"reason\": \"Update validation profile.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/validation-profile"
          },
          "response": []
        },
        {
          "name": "Get Repeat Cap Policy",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/policies/repeat-cap"
          },
          "response": []
        },
        {
          "name": "Update Repeat Cap Policy",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key", "value": "repeat-cap-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true,\n  \"defaultPercent\": 10,\n  \"minPercent\": 0,\n  \"maxPercent\": 100,\n  \"reason\": \"Set global repeat cap.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/repeat-cap"
          },
          "response": []
        },
        {
          "name": "Set Repeat Cap Override",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key", "value": "repeat-cap-override-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scope\": \"student\",\n  \"scopeId\": \"{{studentId}}\",\n  \"repeatCapPercent\": 15,\n  \"isActive\": true,\n  \"reason\": \"Student-level override.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/repeat-cap/overrides"
          },
          "response": []
        },
        {
          "name": "Get Audit Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit/events?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit", "events"],
              "query": [
                { "key": "limit",  "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
