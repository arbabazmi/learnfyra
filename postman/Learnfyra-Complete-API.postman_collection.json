        {
          "name": "Parent View Child Progress",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/progress/parent/{{childId}}?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "progress", "parent", "{{childId}}"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
