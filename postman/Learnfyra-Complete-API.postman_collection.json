                  { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 11,\n  \"subject\": \"Math\",\n  \"topic\": \"Algebra\",\n  \"difficulty\": \"Easy\",\n  \"questionType\": \"multiple-choice\",\n  \"count\": 3\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
            },
            {
              "name": "Generate Questions — 400 Invalid Type",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type",  "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Fractions\",\n  \"difficulty\": \"Easy\",\n  \"questionType\": \"essay\",\n  \"count\": 3\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "3. Student Routes",
      "description": "Student profile and class joining (requires student role)",
      "item": [
        {
          "name": "Get Student Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/student/profile"
          },
          "response": []
        },
        {
          "name": "Join Class (by Invite Code)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"{{inviteCode}}\"\n}"
            },
            "url": "{{baseUrl}}/api/student/join-class"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Teacher Routes (Class Management)",
      "description": "Class creation and student roster management (requires teacher role)",
      "item": [
        {
          "name": "Create Class",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.classId)    pm.collectionVariables.set('classId', body.classId);",
                  "  if (body.inviteCode) pm.collectionVariables.set('inviteCode', body.inviteCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"4th Grade Math\",\n  \"subject\": \"Math\",\n  \"gradeLevel\": 4,\n  \"period\": \"Period 1\"\n}"
            },
            "url": "{{baseUrl}}/api/class/create"
          },
          "response": []
        },
        {
          "name": "List Class Students",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/class/{{classId}}/students"
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Progress Tracking",
      "description": "Student attempt history, aggregate insights, and parent view",
      "item": [
        {
          "name": "Save Progress (After Attempt)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"worksheetId\": \"{{worksheetId}}\",\n  \"subject\": \"Math\",\n  \"topic\": \"Factors and Multiples\",\n  \"difficulty\": \"Easy\",\n  \"score\": 8,\n  \"totalPoints\": 10,\n  \"timeTakenSeconds\": 600\n}"
            },
            "url": "{{baseUrl}}/api/progress/save"
          },
          "response": []
        },
        {
          "name": "Get Progress History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/progress/history?limit=20&offset=0"
          },
          "response": []
        },
        {
          "name": "Get Performance Insights",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/progress/insights?limit=20"
          },
          "response": []
        },
        {
          "name": "Parent View Child Progress",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{parentToken}}" }],
            "url": "{{baseUrl}}/api/progress/parent/{{studentId}}?limit=20"
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Analytics",
      "description": "Class-level and student-level performance analytics (requires teacher role)",
      "item": [
        {
          "name": "Get Class Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/analytics/class/{{classId}}"
          },
          "response": []
        },
        {
          "name": "Get Student Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/analytics/student/{{studentId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "7. Rewards & Gamification",
      "description": "Student rewards, badges, and streaks",
      "item": [
        {
          "name": "Get Student Rewards Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/rewards/student/{{studentId}}"
          },
          "response": []
        },
        {
          "name": "Get Class Rewards Aggregate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/rewards/class/{{classId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "8. Certificates",
      "description": "Student certificate list and signed download. List captures certificateId + downloadToken automatically.",
      "item": [
        {
          "name": "List Student Certificates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.certificates && body.certificates.length > 0) {",
                  "    pm.collectionVariables.set('certificateId', body.certificates[0].certificateId);",
                  "    pm.collectionVariables.set('certificateDownloadToken', body.certificates[0].downloadToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/certificates?limit=10&offset=0"
          },
          "response": []
        },
        {
          "name": "Download Certificate (HTML)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/certificates/{{certificateId}}/download?token={{certificateDownloadToken}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "9. Question Bank (QB)",
      "description": "Question bank CRUD — list, add, get by ID, record reuse",
      "item": [
        {
          "name": "List Questions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/qb/questions?grade=4&subject=Math&difficulty=Easy&limit=20&offset=0"
          },
          "response": []
        },
        {
          "name": "Add Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('questionId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Fractions\",\n  \"difficulty\": \"Medium\",\n  \"type\": \"multiple-choice\",\n  \"question\": \"What is 1/2 of 20?\",\n  \"options\": [\"A. 8\", \"B. 10\", \"C. 12\", \"D. 15\"],\n  \"answer\": \"B\",\n  \"explanation\": \"1/2 multiplied by 20 equals 10.\",\n  \"standards\": [\"CCSS.MATH.CONTENT.4.NF.B.3\"],\n  \"author\": \"Test Author\"\n}"
            },
            "url": "{{baseUrl}}/api/qb/questions"
          },
          "response": []
        },
        {
          "name": "Get Question by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}"
          },
          "response": []
        },
        {
          "name": "Track Question Reuse",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}/reuse"
          },
          "response": []
        }
      ]
    },
    {
      "name": "10. Admin Control Plane",
      "description": "System policies and configuration. All endpoints require admin role.\nIdempotency-Key header recommended on all PUT requests.",
      "item": [
        {
          "name": "Get Global Policies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/policies"
          },
          "response": []
        },
        {
          "name": "Update Model Routing",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",     "value": "application/json" },
              { "key": "Authorization",    "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key",  "value": "model-routing-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultMode\": \"auto\",\n  \"allowPremium\": true,\n  \"premiumEscalation\": {\n    \"missingCountThreshold\": 15,\n    \"hardQuestionCountThreshold\": 10\n  },\n  \"fallbackOrder\": [\"low\", \"default\", \"premium\"],\n  \"reason\": \"Update model routing policy.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/policies/model-routing"
          },
          "response": []
        },
        {
          "name": "Update Budget Usage",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",     "value": "application/json" },
              { "key": "Authorization",    "value": "Bearer {{adminToken}}" },
              { "key": "Idempotency-Key",  "value": "budget-usage-{{$timestamp}}" }
            ],
            "body": {
              "mode": "raw",
