      ]
    },
    {
      "name": "6. Class",
      "description": "Class creation and student roster. Requires teacher Bearer token.",
      "item": [
        {
          "name": "Create Class",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.classId)    { pm.collectionVariables.set('classId', jsonData.classId); }",
                  "if (jsonData.inviteCode) { pm.collectionVariables.set('inviteCode', jsonData.inviteCode); }",
                  "console.log('classId: ' + jsonData.classId + ', inviteCode: ' + jsonData.inviteCode);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"className\": \"4th Grade Math\",\n  \"grade\": 4,\n  \"subject\": \"Math\"\n}"
            },
            "url": "{{baseUrl}}/api/class/create"
          },
          "response": []
        },
        {
          "name": "List Class Students",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/class/{{classId}}/students"
          },
          "response": []
        }
      ]
    },
