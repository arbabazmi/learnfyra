          "name": "Save Progress",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"worksheetId\": \"{{worksheetId}}\",\n  \"subject\": \"Math\",\n  \"grade\": 4,\n  \"score\": 8,\n  \"totalPoints\": 10,\n  \"timeTaken\": 600,\n  \"answers\": [\n    { \"number\": 1, \"answer\": \"B\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/progress/save"
