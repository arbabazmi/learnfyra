            {
              "name": "Generate Short Answer (Hard)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type",  "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 7,\n  \"subject\": \"ELA\",\n  \"topic\": \"Literary Devices\",\n  \"difficulty\": \"Hard\",\n  \"questionType\": \"short-answer\",\n  \"count\": 2\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
            },
            {
              "name": "Generate Fill-in-Blank (Mixed)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type",  "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 3,\n  \"subject\": \"Math\",\n  \"topic\": \"Addition and Subtraction\",\n  \"difficulty\": \"Mixed\",\n  \"questionType\": \"fill-in-the-blank\",\n  \"count\": 3\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
            },
            {
