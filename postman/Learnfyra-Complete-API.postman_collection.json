        {
          "name": "Get Performance Insights",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/progress/insights?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "progress", "insights"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
