        {
          "name": "Get Progress History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/progress/history?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "progress", "history"],
              "query": [
                { "key": "limit",  "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "response": []
