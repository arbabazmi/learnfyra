                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"grade\": 5,\n  \"subject\": \"Science\",\n  \"topic\": \"Ecosystems\",\n  \"difficulty\": \"Medium\",\n  \"questionType\": \"true-false\",\n  \"count\": 2\n}"
                },
                "url": "{{baseUrl}}/api/generate-questions"
              },
              "response": []
