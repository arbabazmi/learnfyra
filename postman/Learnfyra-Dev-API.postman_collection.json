    {
      "name": "Class",
      "description": "Class creation and student roster. Requires teacher Bearer token.",
      "item": [
        {
          "name": "Create Class",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.classId)    { pm.collectionVariables.set('classId', jsonData.classId); }",
                  "if (jsonData.inviteCode) { pm.collectionVariables.set('inviteCode', jsonData.inviteCode); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"className\": \"Grade 4 Math A\",\n  \"grade\": 4,\n  \"subject\": \"Math\"\n}"
            },
            "url": "{{baseUrl}}/api/class/create"
