    {
      "name": "Question Bank",
      "description": "Question bank CRUD. GET endpoints are unauthenticated; POST requires Bearer token.",
      "item": [
        {
          "name": "List Questions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/qb/questions?grade=4&subject=Math&difficulty=Easy&type=multiple-choice",
              "host": ["{{baseUrl}}"],
              "path": ["api", "qb", "questions"],
              "query": [
                { "key": "grade",      "value": "4" },
                { "key": "subject",    "value": "Math" },
                { "key": "difficulty", "value": "Easy" },
                { "key": "type",       "value": "multiple-choice" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Add Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('questionId', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grade\": 4,\n  \"subject\": \"Math\",\n  \"topic\": \"Factors\",\n  \"difficulty\": \"Easy\",\n  \"type\": \"multiple-choice\",\n  \"question\": \"Which number is a factor of 24?\",\n  \"options\": [\"A. 5\", \"B. 6\", \"C. 7\", \"D. 11\"],\n  \"answer\": \"B\",\n  \"explanation\": \"6 divides 24 evenly.\",\n  \"points\": 1,\n  \"standards\": [\"CCSS.MATH.CONTENT.4.OA.B.4\"]\n}"
            },
            "url": "{{baseUrl}}/api/qb/questions"
          },
          "response": []
        },
        {
          "name": "Get Question by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}"
          },
          "response": []
        },
        {
          "name": "Track Question Reuse",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/qb/questions/{{questionId}}/reuse"
          },
          "response": []
        }
      ]
