    {
      "name": "Certificates",
      "description": "Student certificates. Requires student Bearer token.",
      "item": [
        {
          "name": "List Certificates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.certificates && jsonData.certificates.length > 0) {",
                  "  pm.collectionVariables.set('certificateId', jsonData.certificates[0].certificateId || jsonData.certificates[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/certificates?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "certificates"],
              "query": [
                { "key": "limit",  "value": "20" },
                { "key": "offset", "value": "0" }
              ]
