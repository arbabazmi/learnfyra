  "item": [
    {
      "name": "Auth",
      "description": "Authentication — no token required. Run Register then Login to capture tokens.",
      "item": [
        {
          "name": "Register (Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token)  { pm.collectionVariables.set('studentToken', jsonData.token); }",
                  "if (jsonData.userId) { pm.collectionVariables.set('studentId', jsonData.userId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student+dev@test.com\",\n  \"password\": \"Passw0rd123!\",\n  \"role\": \"student\",\n  \"displayName\": \"Dev Student\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": []
        },
        {
          "name": "Register (Teacher)",
          "event": [
            {
              "listen": "test",
              "script": {
