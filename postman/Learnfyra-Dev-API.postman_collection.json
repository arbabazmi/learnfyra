          "name": "Download Certificate",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/api/certificates/{{certificateId}}/download"
          },
          "response": []
