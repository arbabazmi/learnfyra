{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 3000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "learnfyra-app"
    },
    {
      "name": "admin",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5174"],
      "port": 5174,
      "cwd": "learnfyra-admin"
    },
    {
      "name": "docs-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "learnfyra-docs", "-c-1"],
      "port": 8080,
      "autoPort": true
    }
  ]
}
